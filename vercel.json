{
  "version": 2,
  "builds": [
    {
      "src": "backend/App.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/App.py"
    },
    {
      "src": "/admin",
      "dest": "frontend/admin.html"
    },
    {
      "src": "/admin.html",
      "dest": "frontend/admin.html"
    },
    {
      "src": "/chatbot.js",
      "dest": "frontend/chatbot.js"
    },
    {
      "src": "/index.html",
      "dest": "frontend/index.html"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    }
  ]
}
